# GSL Bot — Environment Variables
# Copy this file to .env and fill in your values
# On Railway/Render, add these in the dashboard instead

# Your Discord bot token (from Discord Developer Portal)
BOT_TOKEN=your_bot_token_here

# Channel ID where YOU type !results
RESULTS_CHANNEL=123456789012345678

# Channel ID where winners are announced
ANNOUNCE_CHANNEL=123456789012345678

# Channel ID where the website webhook posts submissions
SUBMISSIONS_CHANNEL=123456789012345678

# Your Discord user ID (right-click yourself → Copy User ID)
# Only you can run !results if this is set
ADMIN_USER_ID=123456789012345678
